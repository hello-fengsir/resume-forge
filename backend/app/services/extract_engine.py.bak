"""信息提取引擎"""
import json, re
from openai import AsyncOpenAI
from app.config import get_settings

class ExtractEngine:
    PROMPT = """从文本中提取简历相关信息。返回纯JSON数组，每个元素字段：
{"category":"work_experience|project|education|skill|certification","title":"...","company":"...","start_date":"YYYY-MM","end_date":"YYYY-MM","content":"...","skills":["..."]}
只输出JSON，不要markdown代码块。"""

    def __init__(self):
        s = get_settings()
        self.client = AsyncOpenAI(api_key=s.DEEPSEEK_API_KEY, base_url=s.DEEPSEEK_BASE_URL)
        self.model = s.GENERATE_MODEL

    async def extract(self, text: str) -> list[dict]:
        resp = await self.client.chat.completions.create(
            model=self.model, max_tokens=4096,
            messages=[{"role":"system","content":self.PROMPT},{"role":"user","content":text}],
        )
        raw = resp.choices[0].message.content or ""
        # Clean markdown code blocks
        raw = re.sub(r'```\w*\n?', '', raw).replace('```', '').strip()
        try:
            data = json.loads(raw)
        except:
            # Try extracting array from text
            m = re.search(r'\[.*\]', raw, re.DOTALL)
            if m: data = json.loads(m.group())
            else: return []
        if isinstance(data, list): return data
        for v in data.values():
            if isinstance(v, list): return v
        return []
